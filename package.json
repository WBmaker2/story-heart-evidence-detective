{
  "name": "story-heart-evidence-detective",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "npm run test:unit && npm run build && node --test tests/rendered-html.test.mjs",
    "test:unit": "node --experimental-strip-types --test tests/domain/*.test.ts tests/content/*.test.ts tests/ui/*.test.ts tests/scripts/*.test.ts",
    "test:domain": "node --experimental-strip-types --test tests/domain/*.test.ts",
    "test:content": "node --experimental-strip-types --test tests/content/*.test.ts",
    "check:content": "node --experimental-strip-types scripts/check-content.ts",
    "check:file-lengths": "node --experimental-strip-types scripts/check-file-lengths.ts",
    "check:release": "node --experimental-strip-types scripts/check-release.ts",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "verify": "npm run typecheck && npm run lint && npm run check:file-lengths && npm run check:content && npm run check:release && npm test",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
